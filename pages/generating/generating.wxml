<view class="page generating-page">
  <view class="brand-row">
    <view class="brand"><view class="brand-mark"></view><text>知识跃迁</text></view>
    <text class="tag">{{modeText}}</text>
  </view>

  <view class="card hero">
    <text class="tag">结构化出题</text>
    <view class="hero-title">正在把知识压缩成关卡</view>
    <view class="hero-subtitle">系统正在提炼考点、生成选项并校验答案结构。</view>
    <image class="hero-character" src="/assets/characters/cyan-idol.svg" mode="aspectFit" />
  </view>

  <view class="scan-card">
    <view class="scan-ring">
      <view class="scan-core">
        <text>{{progress}}</text>
        <text>生成进度</text>
      </view>
    </view>
  </view>

  <view class="card log-card">
    <block wx:for="{{steps}}" wx:key="title">
      <view class="log-item">
        <view class="log-dot {{item.failed ? 'failed' : item.done ? 'done' : ''}}">{{item.failed ? '!' : item.done ? '✓' : item.index}}</view>
        <view class="log-copy">
          <text>{{item.title}}</text>
          <text>{{item.desc}}</text>
        </view>
        <text class="tag {{item.failed ? 'failed' : item.done ? 'mint' : ''}}">{{item.failed ? '失败' : item.done ? '完成' : '进行中'}}</text>
      </view>
    </block>
    <view class="progress-track">
      <view class="progress-bar {{failed ? 'failed' : ''}}" style="width: {{progress}}%;"></view>
    </view>
  </view>

  <view class="guide card">
    <image class="guide-avatar" src="/assets/characters/cyan-idol.svg" mode="aspectFit" />
    <view>
      <text>领航员提示</text>
      <text wx:if="{{failed}}">{{errorMessage}}</text>
      <text wx:else>正在调用本地 Python 后端生成题目；流式不可用时会自动切换为轮询生成。</text>
    </view>
  </view>

  <button wx:if="{{failed}}" class="primary-btn retry-btn" bindtap="retryGenerate">重试生成</button>
  <button class="secondary-btn" bindtap="backHome">返回重新输入</button>
</view>
