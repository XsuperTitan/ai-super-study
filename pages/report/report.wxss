.screen {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 52rpx;
  color: #16233f;
}

.hero-card,
.section,
.stat-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(82, 135, 202, 0.28);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: 0 24rpx 60rpx rgba(47, 95, 156, 0.12);
  backdrop-filter: blur(14rpx);
}

.hero-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
  min-height: 260rpx;
  padding: 32rpx;
}

.hero-card::after {
  content: "";
  position: absolute;
  right: -80rpx;
  top: -90rpx;
  width: 260rpx;
  height: 260rpx;
  border: 2rpx solid rgba(76, 151, 255, 0.2);
  border-radius: 50%;
}

.orbit-mark {
  position: relative;
  width: 168rpx;
  height: 168rpx;
  flex: 0 0 168rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.orbit-ring {
  position: absolute;
  inset: 0;
  border: 4rpx solid rgba(56, 176, 255, 0.38);
  border-left-color: #f4bf45;
  border-radius: 50%;
  box-shadow: inset 0 0 26rpx rgba(86, 184, 255, 0.18);
}

.orbit-core {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  line-height: 112rpx;
  text-align: center;
  border-radius: 50%;
  background: linear-gradient(145deg, #17427a, #38b0ff);
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 800;
  box-shadow: 0 18rpx 40rpx rgba(43, 124, 206, 0.26);
}

.hero-copy {
  position: relative;
  flex: 1;
  min-width: 0;
}

.eyebrow {
  color: #3f7ebd;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.title {
  margin-top: 8rpx;
  color: #11284d;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.18;
}

.subtitle {
  margin-top: 14rpx;
  color: #586b86;
  font-size: 26rpx;
  line-height: 1.55;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.stat-card {
  min-height: 116rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.stat-value {
  color: #153966;
  font-size: 32rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 8rpx;
  color: #718096;
  font-size: 22rpx;
}

.section {
  margin-top: 24rpx;
  padding: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  color: #14294c;
  font-size: 30rpx;
  font-weight: 900;
}

.hud-label {
  padding: 8rpx 14rpx;
  border: 1rpx solid rgba(56, 176, 255, 0.34);
  border-radius: 999rpx;
  color: #2f88d8;
  background: rgba(224, 244, 255, 0.72);
  font-size: 18rpx;
  font-weight: 800;
}

.hud-label.warn {
  color: #c45b5b;
  border-color: rgba(236, 118, 118, 0.28);
  background: rgba(255, 236, 236, 0.82);
}

.hud-label.gold {
  color: #986812;
  border-color: rgba(244, 191, 69, 0.34);
  background: rgba(255, 247, 221, 0.86);
}

.map-item + .map-item {
  margin-top: 24rpx;
}

.map-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.map-name {
  color: #304462;
  font-size: 26rpx;
  font-weight: 700;
}

.map-value {
  color: #3f7ebd;
  font-size: 24rpx;
  font-weight: 800;
}

.map-track {
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(37, 76, 125, 0.08);
}

.map-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #42d2be, #38b0ff);
}

.map-fill.good {
  background: linear-gradient(90deg, #2fd7a0, #48c9b0);
}

.map-fill.weak {
  background: linear-gradient(90deg, #ff9f8a, #f0696d);
}

.weak-card,
.advice-card {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  color: #42536d;
  background: rgba(246, 250, 255, 0.84);
  font-size: 26rpx;
  line-height: 1.55;
}

.weak-card + .weak-card,
.advice-card + .advice-card {
  margin-top: 14rpx;
}

.weak-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  flex: 0 0 14rpx;
  border-radius: 50%;
  background: #f0696d;
  box-shadow: 0 0 16rpx rgba(240, 105, 109, 0.32);
}

.advice-card {
  display: block;
  border-left: 6rpx solid #f4bf45;
}

.action-bar {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 28rpx;
}

.primary-btn,
.secondary-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #173d72, #38b0ff);
  box-shadow: 0 20rpx 44rpx rgba(53, 150, 230, 0.24);
}

.secondary-btn {
  color: #153966;
  border: 1rpx solid rgba(72, 138, 210, 0.3);
  background: rgba(255, 255, 255, 0.78);
}
