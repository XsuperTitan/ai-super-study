.screen {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  box-sizing: border-box;
  padding: 28rpx 28rpx 52rpx;
  color: #16233f;
  background:
    radial-gradient(circle at 12% 4%, rgba(46, 255, 233, 0.20), transparent 30%),
    radial-gradient(circle at 92% 0%, rgba(255, 45, 171, 0.14), transparent 30%),
    linear-gradient(142deg, #f2fbff 0%, #fbfdff 48%, #fff5fb 100%);
}

.screen::before,
.screen::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.screen::before {
  opacity: 0.64;
  background-image:
    linear-gradient(115deg, rgba(46, 255, 233, 0.22) 1rpx, transparent 1rpx),
    linear-gradient(rgba(56, 176, 255, 0.12) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 45, 171, 0.10) 1rpx, transparent 1rpx);
  background-size: 144rpx 144rpx, 56rpx 56rpx, 112rpx 112rpx;
}

.screen > view {
  position: relative;
  z-index: 1;
}

.hero-card,
.section,
.stat-card {
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(46, 255, 233, 0.28);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow:
    0 0 0 1rpx rgba(255, 45, 171, 0.12),
    0 24rpx 60rpx rgba(47, 95, 156, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
  backdrop-filter: blur(14rpx);
}

.hero-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
  min-height: 292rpx;
  padding: 32rpx;
}

.hero-card::after {
  content: "";
  position: absolute;
  right: -80rpx;
  top: -90rpx;
  width: 260rpx;
  height: 260rpx;
  border: 2rpx solid rgba(255, 45, 171, 0.18);
  border-radius: 50%;
}

.report-character {
  position: absolute;
  right: 8rpx;
  bottom: -22rpx;
  width: 184rpx;
  height: 242rpx;
  opacity: 0.96;
  filter: drop-shadow(0 20rpx 24rpx rgba(113, 145, 210, 0.16));
}

.orbit-mark {
  position: relative;
  width: 168rpx;
  height: 168rpx;
  flex: 0 0 168rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.orbit-ring {
  position: absolute;
  inset: 0;
  border: 4rpx solid rgba(46, 255, 233, 0.42);
  border-left-color: #ff7bd5;
  border-bottom-color: #d4ff4a;
  border-radius: 50%;
  box-shadow: inset 0 0 28rpx rgba(255, 45, 171, 0.08);
}

.orbit-core {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  line-height: 112rpx;
  text-align: center;
  border-radius: 50%;
  color: #06213d;
  background: linear-gradient(135deg, #2effe9, #d4ff4a 52%, #ff7bd5);
  font-size: 46rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 40rpx rgba(46, 255, 233, 0.20);
}

.hero-copy {
  position: relative;
  flex: 1;
  min-width: 0;
  padding-right: 128rpx;
  z-index: 2;
}

.eyebrow {
  color: #08779a;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.title {
  margin-top: 8rpx;
  color: #11284d;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.18;
}

.subtitle {
  margin-top: 14rpx;
  color: #5e6f86;
  font-size: 26rpx;
  line-height: 1.55;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.stat-card {
  min-height: 116rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.stat-value {
  color: #153966;
  font-size: 32rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 8rpx;
  color: #718096;
  font-size: 22rpx;
}

.section {
  margin-top: 24rpx;
  padding: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  color: #14294c;
  font-size: 30rpx;
  font-weight: 900;
}

.hud-label {
  padding: 8rpx 14rpx;
  border: 1rpx solid rgba(46, 255, 233, 0.36);
  border-radius: 999rpx;
  color: #08779a;
  background: rgba(237, 253, 255, 0.86);
  font-size: 18rpx;
  font-weight: 900;
}

.hud-label.warn {
  color: #c45b5b;
  border-color: rgba(236, 118, 118, 0.28);
  background: rgba(255, 236, 236, 0.82);
}

.hud-label.gold {
  color: #7f6108;
  border-color: rgba(212, 255, 74, 0.46);
  background: rgba(253, 255, 221, 0.88);
}

.map-item + .map-item {
  margin-top: 24rpx;
}

.map-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.map-name {
  color: #304462;
  font-size: 26rpx;
  font-weight: 800;
}

.map-value {
  color: #08779a;
  font-size: 24rpx;
  font-weight: 900;
}

.map-track {
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(46, 255, 233, 0.10);
}

.map-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2effe9, #7ed8ff, #ff7bd5);
}

.map-fill.good {
  background: linear-gradient(90deg, #24d7ba, #d4ff4a);
}

.map-fill.weak {
  background: linear-gradient(90deg, #ff9f8a, #f0696d);
}

.weak-card,
.advice-card {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  color: #42536d;
  background: rgba(246, 252, 255, 0.86);
  border: 1rpx solid rgba(46, 255, 233, 0.16);
  font-size: 26rpx;
  line-height: 1.55;
}

.weak-card + .weak-card,
.advice-card + .advice-card {
  margin-top: 14rpx;
}

.weak-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  flex: 0 0 14rpx;
  border-radius: 50%;
  background: #f0696d;
  box-shadow: 0 0 16rpx rgba(240, 105, 109, 0.32);
}

.advice-card {
  display: block;
  border-left: 6rpx solid #d4ff4a;
}

.action-bar {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 28rpx;
}

.action-bar .span-2 {
  grid-column: span 2;
}

.primary-btn,
.secondary-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.primary-btn {
  color: #06213d;
  background: linear-gradient(105deg, #2effe9 0%, #d4ff4a 48%, #ff7bd5 100%);
  box-shadow: 0 20rpx 44rpx rgba(46, 255, 233, 0.18);
}

.secondary-btn {
  color: #153966;
  border: 2rpx solid rgba(46, 255, 233, 0.28);
  background: rgba(255, 255, 255, 0.82);
}
