<view class="page quiz-page">
  <view class="brand-row">
    <view class="brand"><view class="brand-mark"></view><text>第 {{currentNumber}} 关</text></view>
    <text class="tag gold">标准难度</text>
  </view>

  <view class="topline">
    <text>{{currentNumber}} / {{total}}</text>
    <text class="muted">{{quiz.title}}</text>
  </view>
  <view class="progress-track">
    <view class="progress-bar" style="width: {{progress}}%;"></view>
  </view>

  <view class="coach card">
    <view class="coach-avatar"><view></view></view>
    <text>{{submitted ? '看完解析后再进入下一关，吸收会更稳。' : '先判断题目问的是什么，再看选项。'}}</text>
  </view>

  <view class="question-card card">
    <text class="tag">{{currentQuestion.typeLabel}}</text>
    <view class="question-stem">{{currentQuestion.stem}}</view>
    <view class="trace">考点追溯：{{currentQuestion.sourceTrace}}</view>
  </view>

  <view class="options">
    <block wx:for="{{displayOptions}}" wx:key="id">
      <button class="option {{item.className}}" bindtap="chooseOption" data-id="{{item.id}}" disabled="{{submitted}}">
        <text>{{item.id}}</text>
        <text>{{item.text}}</text>
      </button>
    </block>
  </view>

  <view wx:if="{{submitted}}" class="analysis card">
    <text class="analysis-title">{{isCorrect ? '回答正确' : '已定位知识漏洞'}}</text>
    <text>{{currentQuestion.explanation}}</text>
  </view>

  <button wx:if="{{!submitted}}" class="primary-btn action-btn" disabled="{{!selectedOption}}" bindtap="submitAnswer">锁定答案</button>
  <button wx:else class="primary-btn action-btn" bindtap="nextQuestion">{{isLast ? '生成分析报告' : '进入下一关'}}</button>
  <button class="secondary-btn" bindtap="restart">重新开始</button>
</view>
