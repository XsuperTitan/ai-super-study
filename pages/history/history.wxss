.hero {
  min-height: 260rpx;
  padding: 34rpx;
}

.hero-title {
  width: 430rpx;
  margin-top: 18rpx;
  color: #0f2e54;
  font-size: 44rpx;
  line-height: 1.18;
  font-weight: 900;
}

.hero-subtitle {
  width: 392rpx;
  margin-top: 16rpx;
  color: #5e6f86;
  font-size: 25rpx;
  line-height: 1.7;
}

.hero-character {
  position: absolute;
  right: 10rpx;
  bottom: -18rpx;
  width: 184rpx;
  height: 242rpx;
  opacity: 0.94;
  filter: drop-shadow(0 20rpx 24rpx rgba(113, 145, 210, 0.16));
}

.history-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin: 28rpx 0 20rpx;
}

.danger-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 16rpx;
  color: #b6384d;
  border: 2rpx solid rgba(255, 105, 135, 0.34);
  background: rgba(255, 239, 243, 0.92);
  font-size: 28rpx;
  font-weight: 900;
}

.empty {
  margin-top: 28rpx;
  padding: 30rpx;
  text-align: center;
}

.empty-character {
  width: 140rpx;
  height: 180rpx;
  margin: 0 auto 18rpx;
}

.empty text {
  display: block;
}

.empty text:first-child {
  color: #14345c;
  font-size: 32rpx;
  font-weight: 900;
}

.empty text:last-child {
  margin: 12rpx 0 24rpx;
  color: #5e6f86;
  font-size: 24rpx;
  line-height: 1.55;
}

.history-list {
  margin-top: 20rpx;
}

.history-card {
  padding: 24rpx;
}

.history-card + .history-card {
  margin-top: 20rpx;
}

.history-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.history-head > text:first-child {
  flex: 1;
  min-width: 0;
  color: #14345c;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 900;
}

.history-source {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  color: #45627e;
  background: rgba(246, 250, 255, 0.86);
  border: 2rpx solid rgba(255, 45, 171, 0.10);
  font-size: 24rpx;
  line-height: 1.5;
}

.history-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.history-meta text {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #08779a;
  background: rgba(237, 253, 255, 0.86);
  border: 1rpx solid rgba(46, 255, 233, 0.26);
  font-size: 20rpx;
  font-weight: 800;
}

.delete-btn {
  width: 132rpx;
  height: 56rpx;
  margin-top: 18rpx;
  border-radius: 14rpx;
  color: #b6384d;
  background: rgba(255, 239, 243, 0.9);
  border: 2rpx solid rgba(255, 105, 135, 0.28);
  font-size: 22rpx;
  font-weight: 900;
}
