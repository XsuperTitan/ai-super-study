.hero {
  min-height: 312rpx;
  padding: 34rpx;
}

.hero-title {
  width: 430rpx;
  margin-top: 18rpx;
  color: #0f2e54;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 900;
}

.hero-subtitle {
  width: 392rpx;
  margin-top: 16rpx;
  color: #5e6f86;
  font-size: 25rpx;
  line-height: 1.7;
}

.character {
  display: block;
}

.hero-character {
  position: absolute;
  right: 14rpx;
  bottom: -8rpx;
  width: 210rpx;
  height: 276rpx;
  filter: drop-shadow(0 22rpx 26rpx rgba(46, 255, 233, 0.18));
  z-index: 2;
}

.hero-orbit {
  position: absolute;
  right: -34rpx;
  top: 30rpx;
  width: 240rpx;
  height: 240rpx;
  border: 2rpx solid rgba(46, 255, 233, 0.28);
  border-radius: 50%;
  box-shadow:
    inset 0 0 34rpx rgba(255, 45, 171, 0.08),
    0 0 38rpx rgba(46, 255, 233, 0.08);
}

.hero-orbit::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 44rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d4ff4a;
  box-shadow: 0 0 18rpx rgba(212, 255, 74, 0.44);
}

.input-card {
  padding: 24rpx;
}

.input-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  color: #08779a;
  font-size: 20rpx;
  font-weight: 900;
}

.input-head text:last-child {
  color: #cc3f98;
}

textarea {
  width: 100%;
  height: 228rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(46, 255, 233, 0.18);
  color: #102138;
  background: rgba(245, 253, 255, 0.82);
  font-size: 27rpx;
  line-height: 1.65;
}

.source-hint {
  margin-top: 14rpx;
  color: #6d7892;
  font-size: 22rpx;
  line-height: 1.5;
}

.quick-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 12rpx;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-panel {
  margin-top: 26rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(46, 255, 233, 0.18);
}

.secondary-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 18rpx;
}

.start-btn {
  width: 100%;
  height: 92rpx;
  margin-top: 0;
  font-size: 30rpx;
  line-height: 92rpx;
}

.secondary-action-row .secondary-btn {
  width: 100%;
  min-width: 0;
  height: 84rpx;
  font-size: 26rpx;
  line-height: 84rpx;
  white-space: nowrap;
}

.recommend-title {
  margin-top: 18rpx;
  color: #6d7892;
  font-size: 22rpx;
  font-weight: 800;
}

.quick-chip,
.pill {
  min-width: 132rpx;
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(46, 255, 233, 0.24);
  color: #315171;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: inset 0 0 0 1rpx rgba(255, 45, 171, 0.05);
  font-size: 24rpx;
  font-weight: 800;
}

.quick-chip {
  width: 100%;
  min-width: 0;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.2;
}

.pill.active {
  color: #08779a;
  background: #eaffff;
  border-color: rgba(46, 255, 233, 0.52);
  box-shadow:
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.72),
    0 0 18rpx rgba(46, 255, 233, 0.12);
}

.flow-card {
  padding: 22rpx;
}

.flow-character {
  position: absolute;
  right: 8rpx;
  bottom: -18rpx;
  width: 128rpx;
  height: 168rpx;
  opacity: 0.2;
}

.flow-step {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid rgba(46, 255, 233, 0.10);
}

.flow-step:last-child {
  border-bottom: 0;
}

.flow-step > text {
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 auto;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #08779a;
  background: #eaffff;
  border: 2rpx solid rgba(46, 255, 233, 0.28);
  font-weight: 900;
}

.flow-step view text:first-child {
  display: block;
  color: #14345c;
  font-weight: 900;
  margin-bottom: 6rpx;
}

.history-btn,
.continue-btn {
  margin-top: 0;
}
